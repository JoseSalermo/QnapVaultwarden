# QNAP LAN IP. Caddy serves the vault cert for BOTH this IP and qnap.local.
# Reach the vault by IP — it works on the LAN and over the VPN (mDNS ".local"
# names don't resolve across a VPN tunnel). Leave blank if you only ever use
# qnap.local on the LAN.
VAULT_HOST=

# Public URL clients use to reach the vault. Match how you actually browse to
# it; using the IP (https://<VAULT_HOST>:8443) is recommended so the LAN and
# VPN behave identically.
DOMAIN=https://qnap.local:8443

# Host port for the Caddy HTTPS listener.
HTTPS_PORT=8443

# Shared external docker network (created by HomelabInfra).
HOMELAB_DOCKER_NETWORK=homelab

# Disable open registration after creating the first account.
SIGNUPS_ALLOWED=false
INVITATIONS_ALLOWED=true

# Argon2 hash of the admin password. Generate with:
#   docker run --rm -it vaultwarden/server /vaultwarden hash
# IMPORTANT: Compose treats `$` as variable syntax. Double EVERY `$` in the
# hash so it is passed literally, e.g. the tool output
#   $argon2id$v=19$m=65540,...
# must be stored here as
#   $$argon2id$$v=19$$m=65540,...
ADMIN_TOKEN=

# SMTP (optional, used for invites + password hints). Pull from Vault.
# Email is DISABLED by default (the SMTP_* lines are commented out in
# docker-compose.yml). To enable: uncomment them there AND fill these in.
# SMTP_SECURITY must be one of: starttls, force_tls, off.
#SMTP_HOST=
#SMTP_FROM=
#SMTP_PORT=587
#SMTP_SECURITY=starttls
#SMTP_USERNAME=
#SMTP_PASSWORD=
