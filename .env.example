# Public URL clients use to reach the vault (VPN/LAN only).
DOMAIN=https://qnap.local:8443

# Host port for the Caddy HTTPS listener.
HTTPS_PORT=8443

# Shared external docker network (created by HomelabInfra).
HOMELAB_DOCKER_NETWORK=homelab

# Disable open registration after creating the first account.
SIGNUPS_ALLOWED=false
INVITATIONS_ALLOWED=true

# Argon2 hash of the admin password. Generate with:
#   docker run --rm -it vaultwarden/server /vaultwarden hash
# Paste the full "$argon2id$..." string here. Pull from Vault in production.
ADMIN_TOKEN=

# SMTP (optional, used for invites + password hints). Pull from Vault.
SMTP_HOST=
SMTP_FROM=
SMTP_PORT=587
SMTP_SECURITY=starttls
SMTP_USERNAME=
SMTP_PASSWORD=
